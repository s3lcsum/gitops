GITEA__database__DB_TYPE= postgres
GITEA__database__HOST=postgres:5432
GITEA__database__NAME=gitea_db
GITEA__database__USER=gitea_user
GITEA__database__PASSWD=your-secure-database-password

# OIDC is configured in Authentik (terraform/authentik locals: oauth2_applications.gitea) and registered in Gitea via:
#   gitea admin auth add-oauth --name authentik --provider openidConnect --key gitea --secret <from tofu output applications.gitea> ...
# Callback URL in Authentik must stay: https://git.lake.dominiksiejak.pl/user/oauth2/authentik/callback
# (source display name "authentik"; OAuth client_id from Authentik is still "gitea".)

GITEA_RUNNER_TOKEN=your-gitea-runner-token-here

GITEA__mailer__ENABLED=true
GITEA__mailer__FROM=your-email@yourdomain.com
GITEA__mailer__PROTOCOL=smtps
GITEA__mailer__SMTP_ADDR=smtp.yourmailprovider.com
GITEA__mailer__SMTP_PORT=587
GITEA__mailer__USER=your-smtp-username
GITEA__mailer__PASSWD=your-smtp-password
