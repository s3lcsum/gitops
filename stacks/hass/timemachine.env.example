# Copy to /opt/hass/timemachine.env on the Portainer host (not committed: **/*.env).
# Enable the service: set stack env COMPOSE_PROFILES=timemachine (Portainer stack env
# or shell) so `ha-time-machine` is included; core services do not need this file.
# Create a token in Home Assistant: your profile → Long-Lived Access Tokens.
# Leave empty to configure credentials only in the Time Machine web UI.
LONG_LIVED_ACCESS_TOKEN=
